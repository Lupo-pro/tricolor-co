# Dependencies
node_modules/

# macOS
.DS_Store

# Environment
.env
.env.local
.env.*.local

# Build output
dist/
build/

# Vercel
.vercel

# External Claude skills installed via `npx skills add` — tracked in skills-lock.json
.agents/
.claude/skills/browser-use
.claude/skills/frontend-design

# Logs
*.log
npm-debug.log*

# Editor
.vscode/
.idea/
*.swp
*.swo

# Outreach sub-project — local-only runtime state. /outreach/.gitignore
# already covers these inside the subdir; re-listed here as defense in
# depth so a stray `git add outreach/` from the repo root can't leak
# PII or secrets.
outreach/.env
outreach/.env.*
outreach/node_modules/
outreach/data/*.json
!outreach/data/.gitkeep
