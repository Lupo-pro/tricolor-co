# Keep the outreach toolchain out of public Vercel deploys.
# Only /api/track-*.js + /api/unsubscribe.js (in the repo's root /api/)
# need to ship — those land automatically when /outreach/ is excluded.
outreach/

# Archived v1
archive-v1/

# Mockups + raw assets
mockups/

# Source images used only by /content-machine and /outreach local
# scripts (ad creatives, social posts) — never referenced by the live
# site HTML/CSS. ~14MB combined; shipping them bloats the deploy and
# the CDN cache without serving a single visitor.
images/lifestyle/
images/hero/hero-balcon.png

# Exception: the /oferta landing uses the stadium/hinchada shot as the
# background for its storytelling + antes/después bands, so it must ship.
!images/lifestyle/lifestyle-stadium.png

# Local docs that don't need to ship
BRIEF.md
DEPLOY.md
