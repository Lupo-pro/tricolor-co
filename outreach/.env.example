# ============================================
# /outreach/.env — copy this file to /outreach/.env
# Never commit the real .env (already in .gitignore).
# ============================================

# Apify — get at https://apify.com/account/integrations
APIFY_API_TOKEN=apify_api_xxxxxxxxxxxx

# Resend — same key you use for the main /api/ functions
RESEND_API_KEY=re_xxxxxxxxxxxx

# Outreach sender identity
# nay@ is the lead address; if it's not yet verified in Resend
# the sender falls back to hola@latricolor.co with a clear log.
SENDER_EMAIL=nay@latricolor.co
SENDER_NAME=Nay - La Tricolor
REPLY_TO_EMAIL=nay@latricolor.co

# Volume + warm-up
DAILY_SEND_LIMIT=10        # starts at 10/day, escalates per warm-up curve
TARGET_PROFILES=200        # scrape target across both platforms

# Public site URL — used to build tracking + unsubscribe links
PUBLIC_SITE_URL=https://latricolor.co

# Local admin server
ADMIN_PORT=3001
